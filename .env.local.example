# Supabase (required for auth + cloud persistence)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic API (required for AI deep analysis + labels)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: API key for external access to AI endpoints
# If set, non-browser requests need Authorization: Bearer <key>
AI_API_KEY=

# Optional: Alert system
ALERT_API_KEY=
CRON_SECRET=

# Optional: Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: TradingView webhook secret
TRADINGVIEW_WEBHOOK_SECRET=

# Stripe (required for paid subscriptions)
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_UNLIMITED_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_UNLIMITED_PRICE_ID=price_...

# Supabase service role (for Stripe webhook to update subscriptions)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
